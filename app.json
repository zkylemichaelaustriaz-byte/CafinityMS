{
  "expo": {
    "name": "Cafinity",
    "slug": "Cafinity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/cafinity-logo.png",
    "scheme": "cafinity",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Cafinity uses your location to find the nearest coffee branch."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#9c6b44",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Cafinity uses your location to find the nearest coffee branch."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2C170A",
          "image": "./assets/images/cafinity-logo.png",
          "imageWidth": 200,
          "android": {
            "image": "./assets/images/cafinity-logo.png",
            "imageWidth": 180
          }
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#9c6b44"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Cafinity needs photo access so admins can set product images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
