# Copy to scripts/.env (gitignored) and fill in. NEVER commit the real values.
# The service-role key bypasses RLS — keep it OUT of the Expo app and out of git.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Safety gate — must be exactly "true" or the scripts refuse to run.
CAFINITY_DEMO_SEED=true
