# Expo Router (SDK 54) pulls react-server-dom-webpack (used only for React Server
# Components / web output, which this app doesn't use). npm resolves it to a build
# that peers against a newer React than SDK 54's React 19.1, causing a harmless
# ERESOLVE. Accept legacy peer resolution so `npm install` / `expo install` just work.
legacy-peer-deps=true
